# dependencies and build output
/node_modules/
/.next/
/out/
/coverage/
/playwright-report/
/test-results/
*.tsbuildinfo

# local environment and Supabase runtime state
.env
.env.local
.env.*.local
# Deployment env files hold the service-role key, which bypasses every RLS
# policy. `.env.local` was already ignored; `.env.vercel` was not, and is
# exactly the file someone creates to paste into a dashboard.
.env.vercel
.env.vercel.*
.env.production
!.env.example
/supabase/.temp/
/supabase/.branches/

# editor and OS files
.DS_Store
*.swp
*.log

# generated QA output that is not curated evidence
/artifacts/tmp/

# Per-workstream dev build output (NEXT_DIST_DIR)
.next-*
.gstack/

# WS-7 scratch (build logs, probes) — not part of the app
.ws7/
