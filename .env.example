# Public local Supabase endpoint. Safe for the browser when paired with the anon key and RLS.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:56721

# Local anonymous key printed by `npm run db:start`. This is not a privileged service-role key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Server-only privileged key for administrative background jobs only. Never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# Optional independent server-only HMAC key for pseudonymous authentication throttle subjects.
# Use at least 32 random characters. `npm run env:local` creates and preserves a local value.
DITELE_AUTH_RATE_LIMIT_HMAC_KEY=replace-with-at-least-32-random-characters

# Canonical application origin used for origin/CSRF checks and auth redirects.
DITELE_APP_ORIGIN=http://127.0.0.1:3100

# `supabase` is the production-like local mode. `fixture` may be used only for explicitly labelled previews.
DITELE_DATA_MODE=supabase

# External integrations remain disabled until contracts and scoped credentials are approved.
DITELE_AI_PROVIDER=disabled
DITELE_LAB_PROVIDER=disabled
DITELE_INTEGRATION_PROVIDER=disabled
